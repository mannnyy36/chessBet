# ChessBet server environment
# Copy to .env for local development; configure in Render dashboard for prod.

# --- Production (Render) ---
# DATABASE_URL is provided automatically when you attach a Render Postgres
# instance. With it set, db.js connects with SSL.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Comma-separated list of origins allowed by CORS. Set this to your Netlify URL.
# CLIENT_ORIGIN=https://your-app.netlify.app

# JWT signing secret. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# JWT_SECRET=replace-with-a-long-random-string

# Render injects PORT automatically; only set this for non-Render hosts.
# PORT=8000


# --- Local development (only used when DATABASE_URL is unset) ---
# PG_USER=emmanuelosemwengie
# PG_PASSWORD=
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=chessbet
