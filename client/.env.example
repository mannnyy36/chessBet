# ChessBet client environment
# Copy to .env.local for dev; set in Netlify dashboard for prod.
# All vars must start with REACT_APP_ for CRA to expose them.

# Render backend URL once deployed:
# REACT_APP_API_URL=https://chessbet-api.onrender.com

# Defaults to http://localhost:8000 when unset (see src/config.js)
